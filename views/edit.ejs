<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Post</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body>
    <div
      class="w-full min-h-screen bg-gradient-to-br from-zinc-900 via-zinc-800 to-black text-white p-10"
    >
      <!-- Top Bar -->
      <div class="w-full flex justify-between items-center mb-8">
        <a href="/profile" class="text-zinc-400 hover:text-white transition">
          ← Back to Profile
        </a>

        <a
          class="bg-red-500 hover:bg-red-600 transition rounded-full px-5 py-2 text-sm font-semibold shadow-lg"
          href="/logout"
        >
          Logout
        </a>
      </div>

      <% if (!post) { %>

      <!-- Error Card -->
      <div
        class="max-w-xl bg-zinc-800 border border-red-500 rounded-2xl p-6 shadow-xl"
      >
        <h3 class="text-red-400 text-xl mb-2">Post not found 😕</h3>
        <a class="text-cyan-400 hover:underline" href="/profile">
          Go back to profile
        </a>
      </div>

      <% } else { %>

      <!-- Edit Card -->
      <div
        class="max-w-xl bg-zinc-800 border border-zinc-700 rounded-2xl p-8 shadow-xl"
      >
        <h3 class="text-2xl font-semibold text-amber-400 mb-2">
          Edit your post ✏️
        </h3>
        <p class="text-zinc-400 mb-6">Make changes and update your post</p>

        <form action="/edit/<%= post._id %>" method="post">
          <textarea
            name="content"
            rows="5"
            class="w-full p-4 mb-5 resize-none rounded-xl bg-zinc-900 border border-zinc-700 outline-none focus:ring-2 focus:ring-amber-500 transition"
          >
<%= post.content %></textarea
          >

          <input
            class="px-6 py-2 bg-amber-500 hover:bg-amber-600 transition text-black font-semibold rounded-full cursor-pointer"
            type="submit"
            value="Update Post"
          />
        </form>
      </div>

      <% } %>
    </div>
  </body>
</html>
